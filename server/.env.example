# Job Board Server Environment Configuration

# Application
NODE_ENV=development
PORT=3000


# Database (Required)
DATABASE_URL=postgresql://postgres:password@localhost:5432/job_board

# JWT Configuration (Required)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long
JWT_EXPIRES_IN=24h

# Redis (Optional - for sessions, caching, rate limiting)
REDIS_URL=redis://localhost:6379

# CORS (Optional)
CORS_ORIGIN=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# S3 / File Storage (Required)
# For development with LocalStack
S3_BUCKET=job-board-uploads
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_ENDPOINT=http://localhost:4566
# S3_PUBLIC_URL=http://localhost:4566/job-board-uploads  # Optional CDN/public URL

# Logging
LOG_LEVEL=info

# Production Example:
# NODE_ENV=production  
# PORT=3000
# DATABASE_URL=postgresql://username:password@hostname:5432/job_board_prod
# JWT_SECRET=a-very-long-cryptographically-secure-random-string-for-production
# JWT_EXPIRES_IN=1h
# REDIS_URL=redis://redis-hostname:6379
# CORS_ORIGIN=https://yourjobboard.com
# S3_BUCKET=your-production-bucket
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# S3_ENDPOINT=  # Leave empty for real AWS S3
# S3_PUBLIC_URL=https://cdn.yourjobboard.com  # Optional CloudFront CDN URL
# LOG_LEVEL=warn